{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "UserAPI.Api.Middlewares": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "MongoDB",
        "Args": {
          "databaseUrl": "mongodb://root:root@localhost:27017/logs_dev?authSource=admin",
          "collectionName": "application_logs_dev",
          "cappedMaxSizeMb": 512,
          "cappedMaxDocuments": 50000,
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "UserAPI"
    }
  },
  "Jwt": {
    "Key": "af3b1d967c45e0df2b84ca91fe3a9d6f1148e2c0e9b7d04a51f396cb8f0a7d32",
    "Issuer": "OrchestrationAPI",
    "Audience": "https://api.OrchestrationAPI.com"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Username": "admin",
    "Password": "admin",
    "Exchanges": {
      "UserCreated": "user-created-exchange"
    }
  },
  "ConnectionStrings": {
    "MS_UserAPI": "Server=localhost,1433;Database=MS_UsersAPI;User Id=sa;Password=Fiap@1234;TrustServerCertificate=True",
    "Redis": "localhost:6379"
  }
}
